# Force LF line endings for source files
* text=auto eol=lf

# Explicit per-extension overrides
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.mdx       text eol=lf
*.sh        text eol=lf

# Binary / vendored — no line-ending normalization
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary

# Generated
pnpm-lock.yaml text eol=lf
