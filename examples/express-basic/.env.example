# Server port (default: 3000)
PORT=3000

# Set to "production" to enable Basic auth on the dashboard
# and disable body capture. Default: "development".
NODE_ENV=development

# Password for the dashboard when NODE_ENV=production.
# Used as the Basic-auth password (user is always "admin").
# Required in production; the example defaults to "change-me"
# so you do not lock yourself out before setting this.
XRAY_DASHBOARD_PASS=change-me
