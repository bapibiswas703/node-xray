{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@node-xray/core": ["../../packages/core/src/index.ts"],
      "@node-xray/dashboard": ["../../packages/dashboard/src/index.ts"],
      "@node-xray/express": ["../../packages/express/src/index.ts"],
      "@node-xray/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
