{
  "name": "@node-xray/express",
  "version": "0.1.0",
  "description": "Express middleware for node-xray",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo .tsup *.tsbuildinfo"
  },
  "dependencies": {
    "@node-xray/core": "workspace:*",
    "@node-xray/types": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "express": "^4.21.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "express": "^4.19.0 || ^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
