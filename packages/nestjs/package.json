{
  "name": "@node-xray/nestjs",
  "version": "0.3.0",
  "description": "NestJS module for node-xray",
  "repository": {
    "type": "git",
    "url": "https://github.com/bapibiswas703/node-xray"
  },
  "homepage": "https://github.com/bapibiswas703/node-xray#readme",
  "bugs": {
    "url": "https://github.com/bapibiswas703/node-xray/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo .tsup *.tsbuildinfo"
  },
  "dependencies": {
    "@node-xray/core": "^0.4.0",
    "@node-xray/dashboard": "^0.2.2",
    "@node-xray/types": "^0.2.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.2.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}

