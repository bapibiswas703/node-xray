{
  "name": "@node-xray/core",
  "version": "0.4.0",
  "description": "Core runtime engine for node-xray: async context, event store, loop monitor, WebSocket hub, redactor",
  "repository": {
    "type": "git",
    "url": "https://github.com/bapibiswas703/node-xray"
  },
  "homepage": "https://github.com/bapibiswas703/node-xray#readme",
  "bugs": {
    "url": "https://github.com/bapibiswas703/node-xray/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo .tsup *.tsbuildinfo"
  },
  "dependencies": {
    "@node-xray/types": "^0.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
